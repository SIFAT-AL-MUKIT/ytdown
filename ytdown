# ---------- [ METADATA FIXER (PROFESSIONAL) ] ----------
def fix_metadata_manually(filepath, title, artist, album):
    """
    প্রফেশনাল ট্যাগিং সিস্টেম।
    অ্যালবাম নাম না থাকলে টাইটেল ব্যবহার হবে (Single হিসেবে)।
    """
    if not mutagen: return

    try:
        ext = os.path.splitext(filepath)[1].lower()
        
        # 1. Opus (.opus)
        if ext == '.opus':
            try:
                audio = OggOpus(filepath)
                audio['title'] = title
                audio['artist'] = artist
                if album: audio['album'] = album
                audio.save()
            except: pass

        # 2. MP3 (.mp3)
        elif ext == '.mp3':
            try:
                audio = EasyID3(filepath)
                audio['title'] = title
                audio['artist'] = artist
                if album: audio['album'] = album
                audio.save()
            except: pass

        # 3. M4A (.m4a)
        elif ext == '.m4a':
            try:
                audio = MP4(filepath)
                audio.tags["\xa9nam"] = title # Title
                audio.tags["\xa9ART"] = artist # Artist
                if album: audio.tags["\xa9alb"] = album # Album
                audio.save()
            except: pass
                
    except Exception:
        pass

