# ---------- [ LOGIC ] ----------
def check_lib_availability():
    if yt_dlp is None or mutagen is None:
        show_error("Core libraries missing!")
        console.print("[yellow]Please go to [bold]Requirements[/] menu and install tools.[/]")
        Prompt.ask("\n[dim]Press Enter...[/]")
        return False
    return True

def get_lyrics_logic(title, manual_search=False):
    search_term = title
    if not manual_search:
        for w in ["(Official Video)", "[Official Video]", "(Lyrics)", "[Lyrics]", "(Official Audio)", "MV"]:
            search_term = search_term.replace(w, "").strip()
    
    console.print(f"\n[bold blue]🔍 Searching Synced Lyrics for:[/] [italic white]{search_term}[/]")
    
    clean_filename = search_term.replace(" ", "_")
    lrc_path = os.path.join(SAVE_DIR, f"{clean_filename}.lrc")

    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        transient=True,
    ) as progress:
        progress.add_task(description="Fetching from database...", total=None)
        os.system(f'syncedlyrics "{search_term}" -o "{lrc_path}" > /dev/null 2>&1')

    if os.path.exists(lrc_path):
        console.print(f"[green]✅ Lyrics saved: {clean_filename}.lrc[/]")
    else:
        console.print("[yellow]⚠️  Lyrics not found automatically.[/]")

def download_engine(url, mode_opts):
    if not check_lib_availability(): return None

    if 'postprocessors' not in mode_opts:
        mode_opts['postprocessors'] = []

    mode_opts['postprocessors'].append({'key': 'EmbedThumbnail'})
    
    base_opts = {
        'outtmpl': f'{SAVE_DIR}/%(title)s.%(ext)s',
        'writethumbnail': True,
        'quiet': False,
        'no_mtime': True,
        'ignoreerrors': True,
        'addmetadata': False, 
    }
    base_opts.update(mode_opts)

    try:
        console.print(f"\n[bold cyan]⬇️  Starting Download...[/]")
        with yt_dlp.YoutubeDL(base_opts) as ydl:
            # 1. Info Fetch
            info = ydl.extract_info(url, download=True)
            
            # 2. Extract Metadata (Smart Logic)
            title = info.get('title', 'Unknown Title')
            artist = info.get('uploader', 'Unknown Artist')
            
            # ইউটিউব যদি অ্যালবাম ডাটা দেয়, সেটা নেওয়া হবে
            # না থাকলে টাইটেলকেই অ্যালবাম (Single) হিসেবে ব্যবহার করা হবে
            album = info.get('album')
            if not album:
                album = title # Fallback to Single

            # 3. Clean Title for Filename
            clean_title = title
            for w in ["(Official Video)", "[Official Video]", "(Lyrics)", "[Lyrics]", "(Official Audio)"]:
                clean_title = clean_title.replace(w, "").strip()
            
            # 4. Determine Filepath
            filename = ydl.prepare_filename(info)
            if 'preferredcodec' in str(mode_opts):
                final_ext = mode_opts['postprocessors'][0].get('preferredcodec', 'opus')
                filepath = os.path.splitext(filename)[0] + '.' + final_ext
            else:
                filepath = filename

            # 5. Apply Professional Tags
            console.print("[dim]Writing smart metadata...[/]")
            fix_metadata_manually(filepath, clean_title, artist, album)
            
            show_success(f"Saved: {clean_title}")
            return clean_title

    except Exception as e:
        show_error(str(e))
        return None

